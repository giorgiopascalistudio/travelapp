{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "travelapp",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-10",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "observability": { "enabled": true }
}
